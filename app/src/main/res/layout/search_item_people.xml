<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/search_item_background"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:layout_marginBottom="6dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="12dp"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:id="@+id/search_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_title"
                android:textStyle="bold"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="16sp" />

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_gender"
                android:textColor="@color/textGray"
                android:textStyle="bold"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/search_gender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/temp_text"
                android:textColor="@color/white"
                android:textStyle="normal"
                android:paddingTop="4dp"
                android:textSize="12sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_count_starships"
                android:textColor="@color/textGray"
                android:textStyle="bold"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/search_starships"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/temp_text"
                android:textColor="@color/white"
                android:textStyle="normal"
                android:paddingTop="4dp"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>